# ---------------------------------------------------------------------------
# Copy to ".env" for local development, or set these in your host (e.g. Vercel).
# ---------------------------------------------------------------------------

# --- Cloud mode (shared, live data for a team) -----------------------------
# When BOTH are set, the app uses Supabase: one shared account, one shared
# dataset, real-time sync. See supabase/schema.sql for the one-time DB setup.
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Local mode (single static login, per-browser data) --------------------
# Used only when Supabase is NOT configured. Defaults: admin / tamu-psv-2026.
# VITE_APP_USERNAME=admin
# VITE_APP_PASSWORD=choose-a-strong-password
